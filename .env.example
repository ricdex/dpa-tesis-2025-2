# Configuración de entorno para AWS CDK y Lambda

# Región de AWS (por defecto us-east-1)
AWS_REGION=us-east-1

# ID de cuenta de AWS (se obtiene automáticamente si no se especifica)
# AWS_ACCOUNT_ID=123456789012

# Nivel de logging de Lambda (DEBUG, INFO, WARNING, ERROR)
LAMBDA_LOG_LEVEL=INFO

# Umbral de decisión para predicción (0-1)
LAMBDA_THRESHOLD=0.3

# Ruta del modelo en S3
LAMBDA_MODEL_KEY=models/mejor_modelo.pkl
