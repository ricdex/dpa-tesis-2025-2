# Variables de entorno para AWS Lambda

# Región de AWS (por defecto us-east-1)
AWS_REGION=us-east-1

# Bucket S3 con el modelo (se genera automáticamente)
# MODEL_BUCKET=ml-retries-model-{ACCOUNT_ID}-{REGION}

# Ruta del modelo en S3
LAMBDA_MODEL_KEY=models/mejor_modelo.pkl

# Umbral de decisión para predicción (0-1)
LAMBDA_THRESHOLD=0.3

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LAMBDA_LOG_LEVEL=INFO
